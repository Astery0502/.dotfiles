# Claude Code skills manifest
# Processed by install.sh
#
# Format:
#   skill-name                          → local skill (stored in claude/skills/, symlinked)
#   skill-name https://github.com/...   → remote skill (git-cloned to ~/.claude/skills/)
#   plugin:identifier@source            → Claude Code plugin (installed via claude plugins install)

# Local skills (stored in this repo)
planning-orchestration
planning-with-files

# Remote skills (downloaded by install.sh, not stored in this repo)
claude-skill-model-fingerprint https://github.com/rt22766/claude-skill-model-fingerprint

# Plugins (installed via claude plugins install)
plugin:superpowers@claude-plugins-official
